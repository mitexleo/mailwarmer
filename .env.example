# SMTP Server
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
USE_TLS=false

# Sender info
FROM_NAME=
FROM_EMAIL=

# Email subject
EMAIL_SUBJECT=

# Warm-up schedule
WARMUP_DAYS=14
DELAY_BETWEEN_EMAILS=10
DELAY_BETWEEN_DAYS=86400

# State tracking file (can be overridden with -s flag)
STATE_FILE=warmup_state.json

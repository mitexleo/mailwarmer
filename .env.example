# SMTP Server
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
USE_TLS=false

# Sender info
FROM_NAME=
FROM_EMAIL=

# Data file (path to your recipients xlsx)
XLSX_FILE=

# Email content
EMAIL_SUBJECT=
TEXT_TEMPLATE=email_body.txt.template

# Warm-up schedule
WARMUP_DAYS=14
DELAY_BETWEEN_EMAILS=10
DELAY_BETWEEN_DAYS=86400

# State tracking file
STATE_FILE=warmup_state.json
